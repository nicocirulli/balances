// =============================================================================
//  mis-balances — Prisma Schema (REFERENCE ONLY)
//
//  This file documents the data model. The app talks directly to Supabase
//  (a managed PostgreSQL service) via @supabase/supabase-js — there is no
//  Node.js backend, so Prisma Client is not used at runtime.
//
//  The SQL equivalent lives in supabase/schema.sql.
//  Auth (User) is managed by Supabase Auth (auth.users table).
// =============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // postgresql://postgres:[password]@[host]:5432/postgres
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// User
// Managed by Supabase Auth (auth.users). Modelled here for documentation only.
// The "username" field is stored in user_metadata.username in Supabase Auth.
// ---------------------------------------------------------------------------
model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  username     String        // "NICO" | "CLAU"  — stored in user_metadata
  createdAt    DateTime      @default(now()) @map("created_at")

  transactions Transaction[]

  @@map("users") // maps to auth.users in Supabase
}

// ---------------------------------------------------------------------------
// Category
// Seeded with padel-specific categories. Both income and expense types.
// ---------------------------------------------------------------------------
model Category {
  id    String       @id @default(uuid()) @db.Uuid
  name  String       @unique
  type  CategoryType
  color String       @default("#6b7280") // hex colour used in the UI

  transactions Transaction[]

  @@map("categories")
}

// ---------------------------------------------------------------------------
// Transaction
// Core financial record. Linked to a Category and (optionally) to the
// Supabase Auth user who created it via user_id.
// ---------------------------------------------------------------------------
model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  amount        Decimal         @db.Decimal(12, 2)
  currency      String          @default("USD")
  amountUsd     Decimal?        @db.Decimal(12, 2) @map("amount_usd")
  exchangeRate  Decimal?        @db.Decimal(12, 4) @map("exchange_rate")
  type          TransactionType
  concept       String
  date          DateTime        @db.Date
  notes         String          @default("")
  paymentMethod String          @default("Efectivo") @map("payment_method")
  registeredBy  String          @map("registered_by") // "NICO" | "CLAU" — denormalised for display
  createdAt     DateTime        @default(now()) @map("created_at")

  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  userId String? @map("user_id") @db.Uuid // nullable: not set in local mode
  // user   User    @relation(fields: [userId], references: [id])
  // (commented out because User lives in auth.users, a different schema)

  @@map("transactions")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum TransactionType {
  Ingreso
  Egreso
}

enum CategoryType {
  Ingreso
  Egreso
}
